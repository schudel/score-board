# EditorConfig – https://editorconfig.org
# Top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
indent_size = 4

# TypeScript / JavaScript
[*.{ts,js}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# HTML / Angular templates
[*.html]
indent_size = 2

# SCSS / CSS
[*.{scss,css}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown (preserve trailing whitespace for line breaks)
[*.md]
trim_trailing_whitespace = false

# XML / project files
[*.{xml,csproj,sln}]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf
