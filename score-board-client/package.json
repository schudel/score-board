{
  "name": "score-board-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:en-us": "ng serve --configuration=en-us",
    "start:de-de": "ng serve --configuration=de-de",
    "start:de-ch": "ng serve --configuration=de-ch",
    "build": "ng build",
    "build:en-us": "ng build --configuration=en-us",
    "build:de-de": "ng build --configuration=de-de",
    "build:de-ch": "ng build --configuration=de-ch",
    "test": "ng test",
    "tc-test": "ng test --watch=false --reporters=teamcity",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "deploy": "ng build --prod",
    "deploy-localize": "ng build --prod --localize",
    "build-locale:en-us": "ng build --prod --configuration=en-us --output-path=dist/en-us --baseHref /en-us/",
    "build-locale:de-de": "ng build --prod --configuration=de-de --output-path=dist/de-de --baseHref /de-de/",
    "build-locale:de-ch": "ng build --prod --configuration=de-ch --output-path=dist/de-ch --baseHref /de-ch/",
    "build-locale": "npm run build-locale:en-us && npm run build-locale:de-de && npm run build-locale:de-ch"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^9.0.2",
    "@angular/cdk": "^9.0.1",
    "@angular/common": "~9.0.2",
    "@angular/compiler": "~9.0.2",
    "@angular/core": "~9.0.2",
    "@angular/flex-layout": "^9.0.0-beta.29",
    "@angular/forms": "~9.0.2",
    "@angular/localize": "~9.0.2",
    "@angular/material": "^9.0.1",
    "@angular/material-moment-adapter": "^9.0.1",
    "@angular/platform-browser": "~9.0.2",
    "@angular/platform-browser-dynamic": "~9.0.2",
    "@angular/router": "~9.0.2",
    "@aspnet/signalr": "^1.1.4",
    "@ctrl/ngx-emoji-mart": "^2.0.0",
    "@mat-datetimepicker/core": "^4.0.1",
    "@mat-datetimepicker/moment": "^4.0.1",
    "angular-google-charts": "^0.1.6",
    "angular-gridster2": "^9.0.1",
    "blueimp-canvas-to-blob": "^3.29.0",
    "giphy-api": "^2.0.1",
    "jquery": "^3.4.1",
    "karma-teamcity-reporter": "^1.1.0",
    "moment": "^2.24.0",
    "ng-recaptcha": "^5.0.0",
    "ng2-img-max": "^2.1.18",
    "ngx-file-drop": "^8.0.8",
    "ngx-page-scroll": "^7.0.0",
    "ngx-page-scroll-core": "^7.0.0",
    "ngx-quill": "^8.0.0",
    "ngx-toastr": "^12.0.0",
    "quill": "^1.3.7",
    "rxjs": "~6.5.4",
    "tslib": "^1.10.0",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.900.3",
    "@angular/cli": "^9.0.3",
    "@angular/compiler-cli": "~9.0.2",
    "@angular/language-service": "~9.0.2",
    "@fortawesome/fontawesome-free": "^5.12.1",
    "@types/jasmine": "~3.5.5",
    "@types/jasminewd2": "~2.0.8",
    "@types/node": "^13.7.4",
    "codelyzer": "^5.1.2",
    "jasmine-core": "~3.5.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~4.4.1",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~2.1.1",
    "karma-jasmine": "^3.1.1",
    "karma-jasmine-html-reporter": "^1.5.2",
    "protractor": "~5.4.3",
    "ts-node": "~8.6.2",
    "tslint": "~6.0.0",
    "typescript": "~3.7.5"
  }
}
